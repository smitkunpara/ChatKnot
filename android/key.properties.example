# Copy this file to android/key.properties and fill in your release keystore values.
# Do not commit android/key.properties.

# Absolute or project-relative path to your release keystore file.
# Example: /home/username/keys/mcp-connector-release.jks
RELEASE_STORE_FILE=

# Keystore password
RELEASE_STORE_PASSWORD=

# Alias of the key inside the keystore
RELEASE_KEY_ALIAS=

# Password for the key alias
RELEASE_KEY_PASSWORD=
