{
  "name": "chatknot",
  "version": "0.4.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "android:apk:release": "cd android && ./gradlew --no-daemon :react-native-worklets:prefabReleasePackage assembleRelease",
    "android:aab:release": "cd android && ./gradlew --no-daemon clean bundleRelease",
